{
	"name": "custom-theme-studio",
	"version": "1.7.16",
	"description": "A complete theme design studio for Obsidian.md. Create, customize, and export professional themes with visual tools, live CSS editing, and instant feedback—all without leaving your workspace.",
	"main": "main.js",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"version": "node version-bump.mjs && git add manifest.json versions.json",
		"release": "node release.mjs",
		"release:minor": "node release.mjs minor",
		"release:major": "node release.mjs major"
	},
	"keywords": [],
	"author": "",
	"license": "MIT",
	"devDependencies": {
		"@types/node": "^16.11.6",
		"@types/prettier": "^2.7.3",
		"@typescript-eslint/parser": "^8.59.3",
		"eslint": "^9.39.4",
		"eslint-plugin-obsidianmd": "^0.3.0",
		"obsidian": "^1.13.1",
		"tslib": "2.4.0",
		"typescript": "~5.4.0",
		"typescript-eslint": "^8.59.3"
	},
	"dependencies": {
		"ace-builds": "^1.43.2",
		"esbuild": "^0.25.8",
		"prettier": "^3.6.2"
	}
}
